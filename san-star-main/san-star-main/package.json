{
  "name": "sanstar-website",
  "version": "1.0.0",
  "description": "SanStar furniture factory website",
  "scripts": {
    "start": "npm-run-all --parallel watch:sass serve",
    "serve": "live-server",
    "watch:sass": "sass --watch src/styles/main.scss:styles/main.css",
    "build:sass": "sass src/styles/main.scss:styles/main.css --style compressed"
  },
  "devDependencies": {
    "live-server": "^1.2.2",
    "npm-run-all": "^4.1.5",
    "sass": "^1.69.5"
  }
} 